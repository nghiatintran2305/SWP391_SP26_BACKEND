# =========================
# Database
# =========================
POSTGRES_URL=jdbc:postgresql://localhost:5432/BE
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password

# =========================
# JWT
# =========================
JWT_SECRET=your-32-characters-or-longer-jwt-secret
JWT_EXPIRATION=86400000

# =========================
# OTP / Mail
# Gmail example: use App Password, not your normal Gmail password
# =========================
OTP_EXPIRATION_MINUTES=10
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
SPRING_MAIL_USERNAME=your-gmail-address@gmail.com
SPRING_MAIL_PASSWORD=your-16-char-gmail-app-password
MAIL_FROM=your-gmail-address@gmail.com
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_SMTP_STARTTLS_REQUIRED=true

# =========================
# Jira
# =========================
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_ADMIN_EMAIL=your-jira-admin-email@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_ADMIN_TOKEN=your-jira-admin-token
ATLASSIAN_ORG_ID=your-atlassian-org-id
JIRA_CLIENT_ID=your-jira-client-id
JIRA_CLIENT_SECRET=your-jira-client-secret
JIRA_REDIRECT_URI=http://localhost:8080/api/v1/jira/oauth/callback

# =========================
# GitHub
# =========================
GITHUB_BASE_URL=https://api.github.com
GITHUB_ADMIN_TOKEN=your-github-admin-token
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_ORG=your-github-org
GITHUB_REDIRECT_URI=http://localhost:8080/api/github/callback
